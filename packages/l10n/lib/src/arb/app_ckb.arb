  "scienceClaimC001Headline": "بیرگە بەپێی هێڵێکی پێشبینیکراو لەدەست دەچێت؛ سەرەتا خێرا، پاشان بەهێواشی.",
  "scienceClaimC002Headline": "ئەو لاپەڕەیەی «لەبیرت چووە» ون نەبووە؛ دووبارە لەبەرکردنەوەی زۆر ئاسانترە لە حیفزکردنی یەکەمجار.",
  "scienceClaimC003Headline": "یەک هەڵە مانای ئەوە نییە لاپەڕەکەت لەدەست داوە.",
  "scienceClaimC004Headline": "خەوی شەو یارمەتی دەدات ئەوەی ئەمڕۆ پێداچوویتەوە لە بیرگەی مەندگاردا جێگیر بێت.",
  "scienceClaimC004Caveat": "بەرنامەکە بەپێی ڕۆژی تەواو کاتبەندی دەکات و خەوت هەڵناسەنگێنێت.",
  "scienceClaimC005Headline": "ئەوەی بەقووڵی و دووبارە لەبەر بکرێتەوە دەگاتە ئاستێکی نزیکەی جێگیر کە دەیان ساڵ دەمێنێتەوە.",
  "scienceClaimC006Headline": "پێداچوونەوە بە بۆشایی گەشەسەندوو زۆر باشتر ڕادەگرێت لە دووبارە خوێندنەوە لە یەک دانیشتندا.",
  "scienceClaimC007Headline": "هەرچی لاپەڕە بەهێزتر بێت، ماوەی نێوان پێداچوونەوەکان زیاد دەکات: ڕۆژانە، ئینجا هەفتانە، ئینجا مانگانە.",
  "scienceClaimC008Headline": "بۆشایی فراوانتر مانای کاری ڕۆژانەی کەمترە بۆ هەمان ئەنجامی مەندگار، نەک تەمەڵی.",
  "scienceClaimC009Headline": "پێداچوونەوەی کەمێک زوو چەند خولەکێک تێدەچێت، بەڵام درەنگی لەوانەیە لاپەڕەکە بدۆڕێنێت؛ بۆیە کەمێک زووتر هەڵدەبژێرین.",
  "scienceClaimC010Headline": "بەرنامەکە کاڵبوونەوەی بیرهێنانەوە بە هێڵێکی ستانداردی کراوەی دووبارەکردنەوەی بۆشاییدارەوە پێشبینی دەکات.",
  "scienceClaimC010Caveat": "ئەم نەگۆڕانە لە سەرەتاوە خەمڵێنراون و لە پێداچوونەوەکانتەوە ڕێک دەخرێن، نەک یاسایەکی ڕەق.",
  "scienceClaimC011Headline": "هەر پێداچوونەوەیەک لە کاتی خۆیدا وا دەکات لاپەڕە درێژتر بمێنێتەوە پێش ئەوەی پێداچوونەوەی نوێی پێویست بێت.",
  "scienceClaimC012Headline": "پێداچوونەوەی لاپەڕە کاتێک کەمێک لاوازترە، زیاتر بەهێزی دەکات لە پێداچوونەوەی کاتێک هێشتا تازەیە.",
  "scienceClaimC013Headline": "دابەشکردنی پێداچوونەوە بەسەر ڕۆژان (و شەوان) باشتر دەمێنێتەوە لە چەپاندنی لە یەک دانیشتندا.",
  "scienceClaimC014Headline": "خولی پێداچوونەوەی نەریتی خۆی دووبارەکردنەوەی بۆشاییدارە؛ بەرنامەکە تەنها لە ناویدا ڕیزبەندی دەگۆڕێت.",
  "scienceClaimC016Headline": "هەر لاپەڕەیەک لانیکەم جارێک لە هەر خولێکدا کە هەڵیدەبژێریت پێداچوونەوەی بۆ دەکرێت — بەرنامەکە تەنها زیاتر دەیکات، نەک کەمتر.",
  "scienceClaimC016Caveat": "ئەمە دڵنیاییەکی بنیاتییە — هەر لاپەڕەیەک لە ناو خولەکەتدا دەگەڕێتەوە — نەک ئەگەرێکی ژمارەیی.",
  "scienceClaimC017Headline": "بەدوای ژمارەیەکی تەواو وەک سەد لەسەد ناکەوین؛ ئەوە کاری ڕۆژانەت چەند بەرامبەر زیاد دەکات و ئەو خولە تێکدەدات کە دەتوانیت بەردەوامی پێ بدەیت.",
  "scienceClaimC017Caveat": "بەرنامەکە ئامانجی نەرم بەکاردەهێنێت؛ ڕاوکردنی ژمارەیەکی نزیک لە تەواوی، کاری ڕۆژانەت چەند بەرامبەر زیاد دەکات.",
  "scienceClaimC018Headline": "لەبەرخوێندنەوە لە یادەوە، حیفزەکەت زۆر زیاتر دەپارێزێت لە دووبارە خوێندنەوە.",
  "scienceClaimC019Headline": "لاپەڕەی بەهێز هەرگیز «تەواو» نابێت؛ تەنها بەردەوامیی لەبەرخوێندنەوە دەیپارێزێت.",
  "scienceClaimC020Headline": "بهێڵە لەبەرخوێندنەوەکە تەواو بێت پێش ڕاستکردنەوە؛ ڕاستکردنەوە لەدوای هەوڵی تەواو باشترین کاریگەری هەیە.",
  "scienceClaimC021Headline": "ئەو مامۆستایەی گوێ لە لەبەرخوێندنەوەکەت دەگرێت و ڕاستی دەکاتەوە، لاپەڕە زیاتر بەهێز دەکات لە هەڵسەنگاندنی خۆت.",
  "scienceClaimC022Headline": "دووبارە خوێندنەوە وا دیارە باشترینە، بەڵام ئەوەی بەڕاستی دەمێنێتەوە لەبەرخوێندنەوەیە لە یادەوە.",
  "scienceClaimC023Headline": "حیفزی مەندگار لە دووبارە لەبەرخوێندنەوە بەدرێژایی کات دێت، نەک لە دووبارەکردنەوەی زیادە لە ڕۆژی حیفزکردندا.",
  "scienceClaimC024Headline": "لەبەرخوێندنەوەی لاپەڕە تاکو بەبێ ماندووبوون ئاسان بێت، لەدەستدانی زۆر گرانتر دەکات.",
  "scienceClaimC025Headline": "بەڵێنت پێ نادەین کە هەرگیز لاپەڕەیەک لەبیر نەکەیت؛ مەندگاری لە پێداچوونەوەی ڕێکوپێکەوە دێت، نەک لە ژمارەیەکی جادوویی.",
  "scienceClaimC025Caveat": "پلەکە بەهێزیی بەڵگە پیشان دەدات، نەک بەڵێن دەربارەی حیفزەکەت.",
  "scienceClaimC026Headline": "زۆربەی لەبیرچوون لە تێکەڵبوونی نێوان بەشە هاوشێوەکانەوەیە، نەک تەنها تێپەڕبوونی کات.",
  "scienceClaimC027Headline": "هەرچی دوو بەش هاوشێوەتر بن زیاتر تێکەڵ دەبن؛ بۆیە تەنها دووبارەکردنەوە جیایان ناکاتەوە.",
  "scienceClaimC028Headline": "بۆ ئەوەی دوو بەشی هاوشێوە تێکەڵ نەکەیت، بەدوای یەکدا مەشقیان بکە تاکو جیاوازییان بزانیت.",
  "scienceClaimC029Headline": "مەشقکردنی تەنها یەکێک لە جووتە هاوشێوەکان لەوانەیە هاوتاکەی لاواز بکات؛ بۆیە هەموو کۆمەڵەکە مەشق دەکەین.",
  "scienceClaimC030Headline": "تێکەڵکردنی ئایەتە هاوشێوەکان هەرچی زیاتر لە قورئان لە یاد بێت، زیاتر ڕوودەدات.",
  "scienceClaimC031Headline": "قورئان بە لاپەڕەی پەیوەست لە یاد دەکەیت و لەبەری دەخوێنیتەوە، نەک کارتی جیاجیا؛ بۆیە بە هەمان شێوە پێداچوونەوەی بۆ دەکەین.",
  "scienceClaimC032Headline": "دووبارە لەبەرخوێندنەوەی هەمان لاپەڕە بە ڕیزبەندی جێگیرەکەی، تەواو ئەوەیە کە جێگیری دەکات.",
  "scienceClaimC033Headline": "هەموو لاپەڕە پلە دەدەین، بەڵام بەووردی شوێنی هەڵەکەت دیاری دەکەین.",
  "scienceClaimC034Headline": "پێداچوونەوەی حیفز بە نەریتی لە سێ ڕێڕەودا ڕێک دەخرێت: نوێ (سەبەق)، نزیک (سەبقی)، و دوور (مەنزیل).",
  "scienceClaimC035Headline": "سوننەت پێداگری لەسەر بەردەوامیی پێداچوونەوە دەکات: قورئان خێراتر لە وشترە بەستراوەکان لە یاد دەردەچێت.",
  "scienceClaimC036Headline": "حەوت مەنزیل قورئان بۆ ختمێکی هەفتانە دابەش دەکەن: پێداچوونەوەی هەموو ئەوەی لە یادتە لانیکەم هەفتەی جارێک.",
  "scienceClaimC037Headline": "شارەزایان سەدان ساڵ پێش پشتڕاستکردنەوەی تاقیکردنەوەکان، گەیشتنە پێداچوونەوەی بۆشاییداری فراوانبوو.",
  "scienceClaimC038Headline": "قورئان ڕووبەڕوو لە مامۆستاوە (تەلەقی) فێر دەکرێت و ڕاست دەکرێتەوە، بە سەنەدێکی پەیوەست تا پێغەمبەر ﷺ.",
  "scienceClaimC039Headline": "نەریت هەموو ئەوەی کەسێک لە یادیەتی بە دەورەیی پێداچوونەوەی بۆ دەکات؛ جبریل هەموو ساڵێک قورئانی لەگەڵ پێغەمبەر ﷺ پێداچووەوە.",
  "scienceClaimC040Headline": "ڕێبازە نەریتییەکان دەق زۆر زیاد فێر دەبن — سەدان دووبارەکردنەوە — پاشان هەموو ئەوەی لە یادە دەگێڕنەوە، نەک بەدوای ژمارەیەکدا بکەون.",
  "scienceClaimC041Headline": "بەئەنقەست زنجیرە و نیشان و هەستی تاوانباری بەکارناهێنین: توێژینەوە دەریدەخات ئەمانە خووی مەندگار دروست ناکەن و لەوانەیە ئەو پاڵنەرە لاواز بکەن کە بۆ پێداچوونەوەت دەهێنێت.",
  "scienceClaimC042Headline": "نەهاتنی یەک ڕۆژ پێشکەوتنەکەت ناسڕێتەوە.",
  "scienceClaimC043Headline": "بیرخستنەوەکان هێمن و بێ گلەیین: «پێداچوونەوەی ئەمڕۆت ئامادەیە»، نەک «حیفزەکەت لەدەست دەدەیت».",
  "scienceClaimC044Headline": "پێشکەوتنت هی خۆتە — وەک نەخشەیەکی هێمنی هەموو قورئانەکەت پیشان دەدرێت، نەک ڕیزبەندی بەرامبەر کەسانی تر.",
  "scienceClaimC045Headline": "کردار بە نیازەکانیانەوەن — بۆیە هەرگیز پێداچوونەوە ناکەینە ڕاوی پاداشت.",
  "scienceClaimC046Headline": "ئەمە یارمەتیدەری پێداچوونەوەیە و خزمەتکاری مامۆستاکەتە — نە جێگرەوەی ڕاستکردنەوەی زارەکی، نە فەتوا.",
  "scienceClaimC047Headline": "لەکوێ زانست نادیار بێت یان بەرنامەکە ساکاری بکات، ئەوە ڕادەگەیەنین — و ناوی هەر سەرچاوەیەک و ساڵی دیاری دەکەین.",
  "scienceClaimC047Caveat": "هەموو ساکارکردنێک ئاشکرا ڕادەگەیەنین: «بەرنامەکە وا بەکاری دەهێنێت؛ توێژینەوە وا بۆ وا پیشان دەدات».",
  "scienceClaimC048Headline": "بەرنامەکە بە تەواوی بێ ئینتەرنێت کار دەکات و هەرگیز دەنگت تۆمار ناکات یان داتاکانت بۆ هیچ شوێنێک نانێرێت."
