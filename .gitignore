# macOS
.DS_Store

# Logs / scratch
*.log

# Auto-saved workflow scripts (Workflow tool)
**/.claude/workflows/

# Flutter / Dart (when the app is scaffolded)
.dart_tool/
.packages
build/
.flutter-plugins
.flutter-plugins-dependencies
.idea/
*.iml

# The single root pubspec.lock IS committed (the §20 audit map) — never ignore
# it; the generated localization source is committed too. Do not add them here.

# Local Quran asset-sourcing working dir (tool/fetch_core_assets.sh downloads
# the ~40-55 MB core set here for the build/integration step; never committed —
# bundling vs build-time-fetch is an open decision, E05-T05/T10).
assets-src/

# Flutter golden-test failure output (regenerable diff PNGs; never committed)
**/failures/

# Core muṣḥaf assets — kept OUT of the code repo (sacred third-party files under
# their own upstream licenses; KFGQPC redistribution unverified). Placed locally
# for the build / obtained via the one-time asset-pack download (CLAUDE.md §8).
# Ignore the asset files by type, but keep the tracked placeholders (README /
# .gitkeep) so the pubspec directory declarations resolve on a fresh checkout.
app/assets/quran/*.xml
app/assets/quran/*.db
app/assets/quran/fonts/*.ttf
